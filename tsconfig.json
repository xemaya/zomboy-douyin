{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "lib": ["ES2017"],
    "types": ["node"]
  },
  "include": ["src/**/*", "adapter/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
